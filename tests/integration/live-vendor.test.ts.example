    // accepts. If the vendor renames a field, this fails immediately with
    // the real server error message.
    //
    // const response = await client.someOperation({ ...minimalValidPayload });
    // expect(response).toBeDefined();
    expect(true).toBe(true);  // <-- delete this once you fill in the real call
  }, 30_000);
});
