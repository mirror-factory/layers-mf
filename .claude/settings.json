{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); CMD=$(echo \"$INPUT\" | grep -o '\"command\"[[:space:]]*:[[:space:]]*\"[^\"]*\"' | head -1 | sed 's/.*\"command\"[[:space:]]*:[[:space:]]*\"\\(.*\\)\"/\\1/'); if echo \"$CMD\" | grep -qE '^git commit'; then .claude/hooks/pre-commit-check.sh ; elif echo \"$CMD\" | grep -qE '^git push'; then .claude/hooks/pre-push-check.sh ; fi",
            "statusMessage": "Running pre-commit/push checks..."
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "PANE=$(tmux display-message -p '#P' 2>/dev/null || echo '0'); if [ \"$PANE\" = '0' ]; then CH='pm'; elif [ \"$PANE\" = '1' ]; then CH='dev'; else CH='pm'; fi; MSGS=$(curl -s --max-time 1 http://localhost:9876/read/$CH 2>/dev/null); if [ -n \"$MSGS\" ] && [ \"$MSGS\" != '[]' ]; then echo \"[INCOMING MESSAGE] $MSGS\"; fi",
            "statusMessage": "Checking messages..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/context7-suggest.py"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/record-skill-use.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/agent-comms.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); FILE=$(echo \"$INPUT\" | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('file_path',''))\" 2>/dev/null); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -qE '\\.(ts|tsx)$'; then echo \"[hook] Edited: $FILE\" >> \"$CLAUDE_PROJECT_DIR\"/.claude/dev-activity.log; fi",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-push-pm.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/verify-claims.py"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/periodic-reground.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/postuse-format.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/track-edits.py"
          }
        ]
      },
      {
        "matcher": "WebFetch|mcp__context7.*|mcp__firecrawl.*|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/record-docs-lookup.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "python3 .claude/hooks/session-start-run.py"
      },
      {
        "type": "command",
        "command": "python3 .claude/hooks/session-startup.py"
      },
      {
        "type": "command",
        "command": "python3 .claude/hooks/record-kit-event.py session-start --phase start --outcome ok"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 .claude/hooks/verify-before-stop.py"
      }
    ]
  }
}
