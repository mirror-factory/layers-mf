{
  "crons": [
    {
      "path": "/api/inbox/generate",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 7 * * 1-5"
    },
    {
      "path": "/api/cron/credit-reset",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/drive-watch-renewal",
      "schedule": "0 */20 * * *"
    },
    {
      "path": "/api/cron/discord-alerts",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/ingest",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/synthesis",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/linear-check",
      "schedule": "*/3 * * * *"
    }
  ],
  "functions": {
    "src/app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/chat/session/[id]/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/ingest/upload/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/integrations/*/sync/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/webhooks/*/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/inbox/generate/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/digest/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/credit-reset/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/drive-watch-renewal/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/discord-alerts/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/ingest/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/synthesis/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/linear-check/route.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
